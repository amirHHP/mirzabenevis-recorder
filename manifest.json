{
  "manifest_version": 3,
  "name": "Mirzabenevis Recorder",
  "version": "1.0.0",
  "description": "Record online meetings and automatically transcribe them to text.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Mirzabenevis Recorder",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
